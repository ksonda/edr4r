```{r, include = FALSE}
knitr::opts_chunk$set(
  collapse = TRUE,
  comment  = "#>",
  fig.path = "usgs-streamgages-figs/",
  fig.width  = 7,
  fig.height = 4,
  dpi        = 96,
  out.width  = "100%"
