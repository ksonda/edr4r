{
  "type": "Coverage",
  "id": "ensemble-grid",
  "domain": {
    "type": "Domain",
    "domainType": "CustomGrid",
    "axes": {
      "realisations": {
        "values": ["control", "perturbed"]
      },
      "y": {
        "values": [40, 41]
      },
      "x": {
        "values": [-110, -109]
      }
    },
    "referencing": [
      {
        "coordinates": ["x", "y"],
        "system": {
          "type": "GeographicCRS",
          "id": "http://www.opengis.net/def/crs/OGC/1.3/CRS84"
        }
      },
      {
        "coordinates": ["realisations"],
        "system": {
          "type": "IdentifierRS",
          "id": "https://example.test/ensemble-members"
        }
      }
    ]
  },
  "parameters": {
    "temperature": {
      "type": "Parameter",
      "observedProperty": {
        "label": "Air temperature"
      },
      "unit": {
        "symbol": "Cel"
      }
    }
  },
  "ranges": {
    "temperature": {
      "type": "NdArray",
      "dataType": "float",
      "axisNames": ["realisations", "y", "x"],
      "shape": [2, 2, 2],
      "values": [1, 2, 3, 4, 5, 6, 7, 8]
    }
  }
}
